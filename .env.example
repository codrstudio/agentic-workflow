# ── App
ENVIRONMENT=development
NODE_ENV=development
VITE_ENV=development

# ── Project Identity and Parameters
PROJECT=agentic-workflow
TIMEZONE=America/Sao_Paulo
CONTEXT_FOLDER=./context

# ══════════════════════════════════════════════════════════════════════
# Port Parameters
PREFIX=21
# ── Source Ports
WEB_PORT=${PREFIX}00
SERVER_PORT=${PREFIX}01
# ── Source Hosts (Docker mode)
WEB_HOST=web.internal
# ══════════════════════════════════════════════════════════════════════

# ── Authentication
SYSUSER=admin@mail.com
SYSPASS=12345678
SYSROLE=sysadmin
JWT_SECRET=backbone-dev-jwt-secret-change-in-production-2026
