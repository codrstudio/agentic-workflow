# ── Ambiente
ENVIRONMENT=development

# ── Projeto e dominio publico (como o usuario acessa o app)
PROJECT=scaffold
PUBLIC_DOMAIN=acme.host.com
PUBLIC_PORT=5000

# ── Portas dos servicos (dev server local)
FRONTEND_PORT=5001
BACKEND_PORT=5002

# ── Hosts internos do proxy (nomes dos containers em producao)
PROXY_FRONTEND_HOST=frontend
PROXY_BACKEND_HOST=backend

# ── Autenticacao JWT (gerar com: npm run gen:jwt-secret)
JWT_SECRET=

# ── PostgreSQL
POSTGRES_USER=scaffold
POSTGRES_PASSWORD=
POSTGRES_DB=scaffold
POSTGRES_PORT=5432

# ── Redis
REDIS_PORT=6379

# ── Tema de cores (slug do tema; vazio = usuario escolhe na interface)
VITE_COLOR_THEME=

# === DEV OVERRIDES (sobrescreve valores acima para rodar local) ===
PUBLIC_DOMAIN=localhost
PROXY_FRONTEND_HOST=localhost
PROXY_BACKEND_HOST=localhost
