{
  "name": "agentic-workflow",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm -w @aw/engine run build",
    "typecheck": "npm -w @aw/engine run typecheck",
    "dev:all": "dotenv -e .env -- concurrently \"npm -w @aw/engine run dev\" \"npm -w @arc/web run dev\" \"npm -w @arc/server run dev\"",
    "aw:run": "dotenv -e .env -- node apps/engine/dist/cli.js",
    "aw:status": "dotenv -e .env -- node apps/engine/dist/status.js",
    "aw:message": "dotenv -e .env -- node apps/engine/dist/message.js",
    "aw:watch": "dotenv -e .env -- node apps/engine/dist/watch-queue.js",
    "aw:console": "dotenv -e .env -- node apps/engine/dist/console.js",
    "env:show": "dotenv -e .env -p SERVER_PORT && dotenv -e .env -p WEB_PORT && dotenv -e .env -p PREFIX"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "dotenv-cli": "^7.4.2",
    "playwright": "^1.58.2"
  }
}
